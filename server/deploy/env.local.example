# Скопируйте в /mnt/ssd/AI-music-notes/.env.local и заполните
# cp env.local.example /mnt/ssd/AI-music-notes/.env.local

# ── Синхронизация с мастером ────────────────────────────────────────────────
IS_LOCAL_SERVER=true
SYNC_MASTER_URL=https://songs-back.nevsky-sobor.ru
SYNC_API_KEY=ваш_секретный_ключ

# ── Локальный доступ (mDNS) ──────────────────────────────────────────────────
# Хостнейм, по которому RPi доступна в локальной сети (без .local суффикса)
LOCAL_HOSTNAME=nevsky-songs.local

# ── Аутентификация ───────────────────────────────────────────────────────────
NEXTAUTH_URL=http://nevsky-songs.local
NEXTAUTH_SECRET=ваш_secret

# ── Бэкенд ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASIC_BACK_URL=http://nevsky-songs.local:4000
